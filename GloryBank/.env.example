# ─────────────────────────────────────────────────────────────────────────────
# GloryBank — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores antes de executar.
# NUNCA comite o arquivo .env com valores reais.
# ─────────────────────────────────────────────────────────────────────────────

# ── OBRIGATÓRIO ──────────────────────────────────────────────────────────────

# Banco de dados PostgreSQL (Neon, Railway, Supabase, etc.)
DATABASE_URL="postgresql://user:password@db.example.com:5432/glorybank?schema=public"

# Chave JWT — OBRIGATÓRIO em produção. Gere com: openssl rand -base64 32
JWT_SECRET="ALTERE_PARA_UMA_CHAVE_SEGURA_COM_MINIMO_32_CARACTERES"

# ── ASAAS BaaS ───────────────────────────────────────────────────────────────
# Sandbox: https://sandbox.asaas.com → Configurações → Integrações
# Produção: https://api.asaas.com/api/v3  (requer aprovação BaaS)
ASSIAS_API_URL="https://sandbox.asaas.com/api/v3"
ASAAS_API_KEY="$aact_your_key_here"

# Token para validar webhooks enviados pelo Asaas
ASAAS_WEBHOOK_TOKEN="token-secreto-para-validar-webhooks-asaas"

# ── MODO DEMO ────────────────────────────────────────────────────────────────
# "true" para demo sem banco real (Login: demo@glorybank.com / Demo@123456)
DEMO_MODE=false

# ── APP URL ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="https://your-app.vercel.app"
